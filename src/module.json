{
    "id": "branchage",
    "name": "Branchage",
    "abbrev": "BRNC",
    "version": "0.4.0",
    "description": "Grids drum maps with per-lane Branches-style note branching",
    "author": "Mutable Instruments ideas / port for Schwung Move",
    "api_version": 2,
    "dsp": "dsp.so",
    "ui": "ui.js",
    "ui_chain": "ui_chain.js",
    "raw_ui": true,
    "capabilities": {
        "midi_in": true,
        "midi_out": true,
        "chainable": true,
        "component_type": "midi_fx"
    },
    "chain_params": [
        { "key": "map_x", "name": "Map X", "type": "float", "min": 0.0, "max": 1.0, "default": 0.5, "step": 0.01 },
        { "key": "map_y", "name": "Map Y", "type": "float", "min": 0.0, "max": 1.0, "default": 0.5, "step": 0.01 },
        { "key": "density_kick", "name": "Kick", "type": "float", "min": 0.0, "max": 1.0, "default": 0.5, "step": 0.01 },
        { "key": "density_snare", "name": "Snare", "type": "float", "min": 0.0, "max": 1.0, "default": 0.5, "step": 0.01 },
        { "key": "density_hat", "name": "Hat", "type": "float", "min": 0.0, "max": 1.0, "default": 0.5, "step": 0.01 },
        { "key": "randomness", "name": "Chaos", "type": "float", "min": 0.0, "max": 1.0, "default": 0.0, "step": 0.01 },
        { "key": "kick_note", "name": "Kick Note", "type": "int", "min": 0, "max": 127, "default": 36, "step": 1 },
        { "key": "snare_note", "name": "Snare Note", "type": "int", "min": 0, "max": 127, "default": 38, "step": 1 },
        { "key": "hat_note", "name": "Hat Note", "type": "int", "min": 0, "max": 127, "default": 42, "step": 1 },
        { "key": "steps", "name": "Steps", "type": "int", "min": 1, "max": 32, "default": 16, "step": 1 },
        { "key": "bpm", "name": "BPM", "type": "int", "min": 40, "max": 240, "default": 120, "step": 1 },
        { "key": "sync", "name": "Sync", "type": "enum", "options": ["move", "internal"], "default": "move" },
        { "key": "kick_branch_prob", "name": "K Branch Prob", "type": "float", "min": 0.0, "max": 1.0, "default": 0.15, "step": 0.01 },
        { "key": "kick_branch_note", "name": "K Branch Note", "type": "int", "min": -1, "max": 127, "default": 35, "step": 1 },
        { "key": "kick_branch_enabled", "name": "K Branch On", "type": "int", "min": 0, "max": 1, "default": 1, "step": 1 },
        { "key": "snare_branch_prob", "name": "S Branch Prob", "type": "float", "min": 0.0, "max": 1.0, "default": 0.20, "step": 0.01 },
        { "key": "snare_branch_note", "name": "S Branch Note", "type": "int", "min": -1, "max": 127, "default": 40, "step": 1 },
        { "key": "snare_branch_enabled", "name": "S Branch On", "type": "int", "min": 0, "max": 1, "default": 1, "step": 1 },
        { "key": "hat_branch_prob", "name": "H Branch Prob", "type": "float", "min": 0.0, "max": 1.0, "default": 0.30, "step": 0.01 },
        { "key": "hat_branch_note", "name": "H Branch Note", "type": "int", "min": -1, "max": 127, "default": 46, "step": 1 },
        { "key": "hat_branch_enabled", "name": "H Branch On", "type": "int", "min": 0, "max": 1, "default": 1, "step": 1 }
    ]
}
