{
    "id": "branchage",
    "name": "Branchage",
    "abbrev": "BRNC",
    "version": "0.3.3",
    "description": "Grids drum maps with per-lane Branches-style note branching",
    "author": "Mutable Instruments ideas / port for Schwung Move",
    "api_version": 2,
    "dsp": "dsp.so",
    "ui": "ui.js",
    "raw_ui": true,
    "capabilities": {
        "midi_in": true,
        "midi_out": true,
        "chainable": true,
        "component_type": "midi_fx"
    },
    "chain_params": [
        { "key": "map_x", "name": "Map X", "type": "float", "min": 0.0, "max": 1.0, "default": 0.5, "step": 0.01 },
        { "key": "map_y", "name": "Map Y", "type": "float", "min": 0.0, "max": 1.0, "default": 0.5, "step": 0.01 },
        { "key": "density_kick", "name": "Kick", "type": "float", "min": 0.0, "max": 1.0, "default": 0.5, "step": 0.01 },
        { "key": "density_snare", "name": "Snare", "type": "float", "min": 0.0, "max": 1.0, "default": 0.5, "step": 0.01 },
        { "key": "density_hat", "name": "Hat", "type": "float", "min": 0.0, "max": 1.0, "default": 0.5, "step": 0.01 },
        { "key": "randomness", "name": "Chaos", "type": "float", "min": 0.0, "max": 1.0, "default": 0.0, "step": 0.01 },
        { "key": "steps", "name": "Steps", "type": "int", "min": 1, "max": 32, "default": 16, "step": 1 },
        { "key": "bpm", "name": "BPM", "type": "int", "min": 40, "max": 240, "default": 120, "step": 1 },
        { "key": "sync", "name": "Sync", "type": "enum", "options": ["move", "internal"], "default": "move" }
    ]
}
